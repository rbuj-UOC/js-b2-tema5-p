{
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "babel-jest": "^30.3.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jest-fetch-mock": "^3.0.3",
    "markdownlint": "^0.40.0",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "test": "jest --watchAll",
    "testu1e1": "jest u1e1",
    "format": "prettier --write **/u[0-9]+e[0-9]+.js **/u[0-9]+e[0-9]+.test.js",
    "lint": "eslint . --ext .js,.jsx"
  },
  "jest": {
    "transform": {
      "^.+\\.[t|j]sx?$": "babel-jest"
    }
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.9.1"
  }
}
